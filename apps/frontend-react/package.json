{
  "name": "frontend-react",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "author": "Enterprise Corp",
  "description": "Vehicle Vision OCR System",
  "build": {
    "appId": "com.enterprise.vehiclevisionocr",
    "productName": "VehicleVisionOCR",
    "directories": {
      "output": "C:/temp/vvoc-build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/vite.svg"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "VehicleVisionOCR"
    },
    "extraResources": [
      {
        "from": "dist-backend-${arch}",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "dist",
        "to": "backend/wwwroot",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "scripts": {
    "dev": "vite",
    "build:react": "tsc -b && vite build",
    "build:backend-x64": "cd ../backend-dotnet && dotnet publish -c Release -r win-x64 --self-contained true -o ../frontend-react/dist-backend-x64",
    "build:backend-ia32": "cd ../backend-dotnet && dotnet publish -c Release -r win-x86 --self-contained true -o ../frontend-react/dist-backend-ia32",
    "build:electron": "electron-builder --win --x64 --ia32",
    "build": "npm run build:react && npm run build:backend-x64 && npm run build:backend-ia32 && npm run build:electron",
    "electron:start": "electron .",
    "dev:app": "concurrently \"npm run dev\" \"cd ../backend-dotnet && dotnet run\" \"wait-on http://localhost:5173 && npm run electron:start\"",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.4.0",
    "@microsoft/signalr": "^10.0.0",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@tanstack/react-query": "^5.101.2",
    "axios": "^1.18.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "notistack": "^3.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  }
}
